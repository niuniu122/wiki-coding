# Product fingerprints read working-tree bytes, so every detected text file must
# check out identically on Windows and Linux regardless of core.autocrlf.
* text=auto eol=lf

*.cjs text eol=lf
*.js text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Migration fixtures are byte-exact historical evidence. Never rewrite them at checkout.
fixtures/compat/migration/** -text
