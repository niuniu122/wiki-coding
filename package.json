{
  "name": "minimax-codex",
  "version": "0.1.0",
  "description": "A Codex-style interactive CLI shell for MiniMax.",
  "type": "module",
  "bin": {
    "minimax-codex": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets --locked -- -D warnings",
    "test": "tsx test/run-tests.ts",
    "test:rust": "cargo test --workspace --locked",
    "eval:retrieval": "tsx src/eval/capability-retrieval-report.ts",
    "eval:provider": "tsx src/eval/provider-conformance.ts",
    "verify:agent": "npm run eval:retrieval && npm run eval:provider",
    "verify:rust-contracts": "cargo run -p minimax-compat-harness --locked -- verify",
    "build:rust:release": "cargo build -p minimax-cli --release --locked",
    "package:rust": "node scripts/release/package-rust.mjs",
    "verify:rust-release": "node scripts/release/verify-rust-release.mjs",
    "verify:release": "npm run check && npm test && npm run check:rust && npm run test:rust && npm run verify:rust-contracts && npm run build && npm run eval:retrieval && npm run eval:provider && npm run build:rust:release && npm run package:rust && npm run verify:rust-release",
    "smoke:provider": "tsx src/smoke/provider-smoke.ts"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^18.3.23",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
