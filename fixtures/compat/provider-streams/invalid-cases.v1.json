      "expected_error": {
        "code": "malformed_json",
        "category": "protocol",
        "forbidden_fragments": ["SECRET_PROVIDER_DETAIL"]
      }
    },
    {
      "case_id": "missing_call_id",
      "protocol": "responses",
      "raw": ["{\"type\":\"response.output_item.added\",\"item\":{\"type\":\"function_call\",\"name\":\"invoke_local_capability\"}}"],
      "expected_error": {
        "code": "missing_call_id",
        "category": "protocol",
        "forbidden_fragments": []
      }
    },
    {
      "case_id": "premature_eof",
      "protocol": "responses",
      "raw": ["{\"type\":\"response.output_text.delta\",\"delta\":\"partial\"}"],
      "expected_error": {
        "code": "premature_eof",
        "category": "protocol",
        "forbidden_fragments": []
      }
    },
    {
      "case_id": "duplicate_terminal",
      "protocol": "chat_completions",
      "raw": ["[DONE]", "[DONE]"],
      "expected_error": {
        "code": "duplicate_terminal",
        "category": "protocol",
        "forbidden_fragments": []
      }
    },
    {
      "case_id": "event_after_terminal",
      "protocol": "responses",
      "raw": [
        "{\"type\":\"response.completed\"}",
        "{\"type\":\"response.output_text.delta\",\"delta\":\"late\"}"
      ],
      "expected_error": {
        "code": "event_after_terminal",
        "category": "protocol",
        "forbidden_fragments": []
      }
    },
    {
      "case_id": "tool_arguments_not_object",
      "protocol": "responses",
      "raw": [
        "{\"type\":\"response.output_item.done\",\"item\":{\"type\":\"function_call\",\"id\":\"item-1\",\"call_id\":\"call-1\",\"name\":\"read_file\",\"arguments\":\"[]\"}}",
        "{\"type\":\"response.completed\"}"
      ],
      "expected_error": {
        "code": "invalid_tool_arguments",
        "category": "protocol",
        "forbidden_fragments": []
      }
    },
    {
      "case_id": "duplicate_tool_call_id",
      "protocol": "chat_completions",
      "raw": [
        "{\"choices\":[{\"delta\":{\"tool_calls\":[{\"index\":0,\"id\":\"call-1\",\"function\":{\"name\":\"read_file\",\"arguments\":\"{}\"}},{\"index\":1,\"id\":\"call-1\",\"function\":{\"name\":\"read_file\",\"arguments\":\"{}\"}}]}}]}"
      ],
      "expected_error": {
        "code": "duplicate_tool_call_id",
        "category": "protocol",
        "forbidden_fragments": []
      }
